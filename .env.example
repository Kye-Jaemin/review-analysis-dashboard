# Database
DATABASE_URL=sqlite+aiosqlite:///./local.db
# Production example: postgresql+asyncpg://user:pass@host:5432/db

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_ALLOWED_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6,claude-opus-4-7

# Reddit (PRAW)
# Create a 'script' type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:review-collector:v0.1 (by /u/yourname)

# Web scraper
SCRAPER_USER_AGENT=review-collector-bot/0.1 (+contact: you@example.com)
PLAYWRIGHT_ENABLED=false

# UI
DEFAULT_LANGUAGE=en

# App
APP_ENV=development
LOG_LEVEL=INFO
ANALYSIS_BATCH_SIZE=8
ANALYSIS_CONCURRENCY=4
